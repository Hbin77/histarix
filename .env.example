# ============================================
# Histarix Docker 환경 변수
# 이 파일을 .env로 복사한 뒤 값을 입력하세요
# cp .env.example .env
# ============================================

# [필수] Mapbox 액세스 토큰
# https://account.mapbox.com/access-tokens/ 에서 발급
NEXT_PUBLIC_MAPBOX_TOKEN=pk.여기에_토큰_입력

# [선택] Supabase (로그인 기능 사용 시)
# https://supabase.com 에서 프로젝트 생성 후 Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [선택] PostHog (분석 기능 사용 시)
# https://posthog.com 에서 프로젝트 생성 후 Project Settings에서 확인
NEXT_PUBLIC_POSTHOG_KEY=

# [자동] 백엔드 API URL - 브라우저에서 접근하는 주소
# 나스 IP가 192.168.x.x라면: http://192.168.x.x:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# [자동] CORS 허용 - 수정 불필요
ALLOWED_ORIGINS=http://localhost:3093,http://localhost

# [자동] Wikipedia User-Agent
WIKIPEDIA_USER_AGENT=Histarix/1.0 (contact@histarix.com)
