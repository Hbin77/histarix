# ============================================
# Histarix Docker 환경 변수
# 이 파일을 .env로 복사한 뒤 값을 입력하세요
# cp .env.example .env
# ============================================

# ---- [필수] 직접 입력해야 하는 값 ----

# Mapbox 액세스 토큰 (지도 표시용)
# https://account.mapbox.com/access-tokens/ 에서 발급
NEXT_PUBLIC_MAPBOX_TOKEN=pk.여기에_토큰_입력

# 백엔드 API URL - 나스 IP에 맞게 수정
# 예: http://192.168.0.10:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- [필수] PostgreSQL 설정 ----
# 원하는 비밀번호로 변경하세요
DB_USER=histarix
DB_PASSWORD=changeme

# ---- [선택] 없어도 기본 기능 동작 ----

# Supabase (소셜 로그인 사용 시)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog (분석 기능 사용 시)
NEXT_PUBLIC_POSTHOG_KEY=

# ---- [자동] 수정 불필요 ----
ALLOWED_ORIGINS=http://localhost:3093,http://localhost
WIKIPEDIA_USER_AGENT=Histarix/1.0 (contact@histarix.com)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/histarix
