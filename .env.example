# ============================================
# Histarix Docker 환경 변수
# 이 파일을 .env로 복사한 뒤 값을 입력하세요
# cp .env.example .env
# ============================================

# [필수] Mapbox 액세스 토큰
NEXT_PUBLIC_MAPBOX_TOKEN=pk.여기에_토큰_입력

# [필수] PostgreSQL 비밀번호
DB_USER=histarix
DB_PASSWORD=changeme

# [자동] 수정 불필요
NEXT_PUBLIC_API_URL=https://histarix.semo3.com
ALLOWED_ORIGINS=https://histarix.semo3.com
WIKIPEDIA_USER_AGENT=Histarix/1.0 (contact@histarix.com)

# [필수] JWT 시크릿 (아래 명령어로 생성: openssl rand -hex 32)
JWT_SECRET=여기에_랜덤_문자열_입력

# [선택] 이메일 인증 (Gmail 앱 비밀번호)
SMTP_USER=
SMTP_PASSWORD=

# [선택] 없어도 동작
NEXT_PUBLIC_POSTHOG_KEY=
